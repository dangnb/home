generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductBadge {
  FEATURED
  BEST_SELLER
  NEW
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum FulfillmentMethod {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  NEW
  REVIEWING
  INTERVIEW
  ACCEPTED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Product {
  id              String               @id @default(cuid())
  slug            String               @unique
  name            String
  category        String
  description     String
  longDescription String
  price           Int
  badge           ProductBadge?
  tone            String?
  status          ProductStatus        @default(ACTIVE)
  sortOrder       Int                  @default(0)
  imageUrl        String?
  tastingNotes    ProductTastingNote[]
  addOns          ProductAddOn[]
  orderItems      OrderItem[]
  reviews         Review[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status, sortOrder])
  @@index([category])
}

model ProductTastingNote {
  id        String  @id @default(cuid())
  productId String
  value     String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductAddOn {
  id        String  @id @default(cuid())
  productId String
  name      String
  price     Int     @default(0)
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Order {
  id              String            @id @default(cuid())
  code            String            @unique
  customerName    String
  customerPhone   String
  customerAddress String?
  customerNote    String?
  fulfillment     FulfillmentMethod
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus     @default(PENDING)
  status          OrderStatus       @default(NEW)
  subtotal        Int
  total           Int
  idempotencyKey  String?           @unique
  items           OrderItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([customerPhone])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String?
  productSlug     String
  productName     String
  productCategory String
  unitPrice       Int
  quantity        Int
  lineTotal       Int
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model NewsPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  authorId    String?
  author      AdminUser? @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
}

model JobPosting {
  id             String           @id @default(cuid())
  slug           String           @unique
  title          String
  location       String
  employmentType String
  description    String
  requirements   String
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  applications   JobApplication[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([isActive, sortOrder])
}

model JobApplication {
  id           String            @id @default(cuid())
  jobPostingId String?
  jobPosting   JobPosting?       @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  fullName     String
  phone        String
  email        String?
  position     String
  message      String
  status       ApplicationStatus @default(NEW)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([phone])
}

model Review {
  id        String       @id @default(cuid())
  productId String?
  product   Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  rating    Int
  comment   String
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([productId, status])
  @@index([status, createdAt])
}

model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  isActive     Boolean    @default(true)
  newsPosts    NewsPost[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
