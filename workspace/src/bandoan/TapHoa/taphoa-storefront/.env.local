# ===========================================
# TapHoa Storefront - Environment Configuration
# ===========================================

# API Backend URL (.NET Minimal API storefront endpoint)
NEXT_PUBLIC_API_URL=http://localhost:5222/api/v1/online-store

# Storefront API Key for backend security filter
NEXT_PUBLIC_STOREFRONT_API_KEY=taphoa-sf-key-2026-secure-random

# Use Mock Data (set to "false" to connect directly to live .NET Backend Server)
NEXT_PUBLIC_USE_MOCK=false
