# ===========================================
# TapHoa Storefront - Environment Configuration
# ===========================================

# API Backend URL
# Change this to your actual backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Use Mock Data (set to "true" to use hardcoded mock data instead of real API)
# Set to "false" or remove to connect to the real backend
NEXT_PUBLIC_USE_MOCK=true
