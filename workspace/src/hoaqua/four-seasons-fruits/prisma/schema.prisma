// Prisma Schema for Four Seasons Fruits E-commerce
// Using SQLite for development (easily switchable to PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// Category Model
// ============================================
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

// ============================================
// Product Model
// ============================================
model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  content     String?     // Rich text content (HTML from editor)
  price       Float
  salePrice   Float?
  image       String?
  images      String?     // JSON array of image URLs
  stock       Int         @default(0)
  unit        String      @default("kg")
  featured    Boolean     @default(false)
  isOnSale    Boolean     @default(false)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  comments    Comment[]
  wishlist    Wishlist[]
  stockHistory StockHistory[]
  importItems  ImportReceiptItem[]
}

// ============================================
// Order Model
// ============================================
model Order {
  id              String      @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  total           Float
  status          String      @default("pending")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

// ============================================
// OrderItem Model
// ============================================
model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  productId String
  product   Product @relation(fields: [productId], references: [id])
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
}

// ============================================
// Admin User Model (for demo authentication)
// ============================================
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Post Model (Store articles / About pages)
// ============================================
model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?  // Short summary
  content     String   // Rich text HTML content
  coverImage  String?  // Cover/banner image URL
  published   Boolean  @default(false)
  type        String   @default("article") // "article" | "about" | "page"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// Store Settings (configurable contact info)
// ============================================
model StoreSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ============================================
// Promotion Model (Chương trình khuyến mại)
// ============================================
model Promotion {
  id          String   @id @default(cuid())
  name        String
  description String?
  discount    Float    // Phần trăm chiết khấu (VD: 10 = 10%)
  type        String   @default("product") // "product" | "category" | "all"
  productIds  String?  // JSON array of product IDs (for type "product")
  categoryIds String?  // JSON array of category IDs (for type "category")
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  minOrder    Float?   // Đơn hàng tối thiểu (optional)
  maxDiscount Float?   // Giảm tối đa (optional)
  code        String?  @unique // Mã khuyến mại (optional)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// Voucher Model (Mã giảm giá cho khách hàng)
// ============================================
model Voucher {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String   @default("percent") // "percent" | "fixed"
  discountValue Float    // Giá trị giảm (% hoặc VND tùy discountType)
  minOrder      Float?   // Đơn tối thiểu
  maxDiscount   Float?   // Giảm tối đa (chỉ dùng khi discountType = percent)
  usageLimit    Int?     // Số lần sử dụng tối đa (null = không giới hạn)
  usedCount     Int      @default(0) // Số lần đã dùng
  perUserLimit  Int      @default(1) // Số lần mỗi người dùng (theo email)
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  usages        VoucherUsage[]
}

// ============================================
// Voucher Usage (Lịch sử sử dụng voucher)
// ============================================
model VoucherUsage {
  id        String   @id @default(cuid())
  voucherId String
  voucher   Voucher  @relation(fields: [voucherId], references: [id])
  email     String   // Email khách hàng
  orderId   String?  // Liên kết đơn hàng
  discount  Float    // Số tiền đã giảm
  createdAt DateTime @default(now())
}

// ============================================
// Chat Models (Live chat between customer & admin)
// ============================================
model ChatConversation {
  id          String        @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  status      String        @default("open") // "open" | "closed"
  lastMessage String?
  lastAt      DateTime?
  unreadAdmin Int           @default(0) // Unread count for admin
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String           // "customer" | "admin"
  content        String
  createdAt      DateTime         @default(now())
}

// ============================================
// Customer User (for login, comment, wishlist)
// ============================================
model Customer {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  avatar    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  comments  Comment[]
  wishlist  Wishlist[]
}

// ============================================
// Product Comment / Review
// ============================================
model Comment {
  id         String   @id @default(cuid())
  content    String
  rating     Int      @default(5) // 1-5 stars
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

// ============================================
// Wishlist (Sản phẩm yêu thích)
// ============================================
model Wishlist {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([productId, customerId])
}

// ============================================
// Stock History (Lịch sử kho)
// ============================================
model StockHistory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String   // "in" (nhập) | "out" (xuất) | "return" (trả hàng) | "adjust" (điều chỉnh)
  quantity  Int      // Số lượng thay đổi (luôn dương)
  reason    String   // Lý do: "Đơn hàng #xxx", "Trả hàng #xxx", "Nhập kho", "Điều chỉnh"
  orderId   String?  // Liên kết đơn hàng (nếu có)
  stockAfter Int     // Tồn kho sau thay đổi
  createdAt DateTime @default(now())
}

// ============================================
// Import Receipt (Phiếu nhập hàng)
// ============================================
model ImportReceipt {
  id           String              @id @default(cuid())
  code         String              @unique // Mã phiếu: PN-20240101-001
  supplier     String              // Nhà cung cấp
  note         String?             // Ghi chú
  totalAmount  Float               @default(0) // Tổng tiền nhập
  status       String              @default("draft") // "draft" | "confirmed" | "cancelled"
  createdBy    String?             // Người tạo
  confirmedAt  DateTime?           // Ngày duyệt
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  items        ImportReceiptItem[]
}

model ImportReceiptItem {
  id              String        @id @default(cuid())
  importReceiptId String
  importReceipt   ImportReceipt @relation(fields: [importReceiptId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int           // Số lượng nhập
  unitPrice       Float         // Giá nhập/đơn vị
  totalPrice      Float         // quantity * unitPrice
}

// ============================================
// Supplier (Nhà cung cấp)
// ============================================
model Supplier {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique // Mã NCC
  phone       String?
  email       String?
  address     String?
  contactName String?  // Người liên hệ
  taxCode     String?  // Mã số thuế
  description String?  // Rich text HTML (editor)
  logo        String?  // Logo URL
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
